{
  "name": "versatile-wordpress-theme",
  "version": "1.0.0",
  "description": "A professional, modern WordPress theme with clean architecture",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass assets/css/src/main.scss assets/css/dist/main.css --style compressed",
    "build:js": "webpack --config build/webpack.config.js --mode production",
    "watch": "npm run watch:css & npm run watch:js",
    "watch:css": "sass assets/css/src/main.scss assets/css/dist/main.css --watch --style compressed",
    "watch:js": "webpack --config build/webpack.config.js --mode development --watch",
    "dev": "npm run watch",
    "lint:css": "stylelint 'assets/css/src/**/*.scss'",
    "lint:js": "eslint 'assets/js/src/**/*.js'",
    "lint": "npm run lint:css && npm run lint:js",
    "format:css": "stylelint 'assets/css/src/**/*.scss' --fix",
    "format:js": "eslint 'assets/js/src/**/*.js' --fix",
    "format": "npm run format:css && npm run format:js"
  },
  "keywords": [
    "wordpress",
    "theme",
    "responsive",
    "modern",
    "professional"
  ],
  "author": "Your Name",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "babel-loader": "^9.1.0",
    "css-loader": "^6.8.0",
    "eslint": "^8.42.0",
    "mini-css-extract-plugin": "^2.7.0",
    "sass": "^1.63.0",
    "sass-loader": "^13.3.0",
    "stylelint": "^15.7.0",
    "stylelint-config-standard-scss": "^9.0.0",
    "webpack": "^5.86.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {},
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ie_mob 11"
  ]
}
