<?xml version="1.0"?>
<ruleset name="Versatile Theme">
    <description>PHP CodeSniffer configuration for Versatile WordPress Theme</description>
    
    <!-- What to scan -->
    <file>.</file>
    
    <!-- Exclude patterns -->
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/assets/css/dist/*</exclude-pattern>
    <exclude-pattern>*/assets/js/dist/*</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.min.css</exclude-pattern>
    
    <!-- How to scan -->
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg value="p"/>
    
    <!-- Rules: Check PHP version compatibility -->
    <config name="testVersion" value="7.4-"/>
    
    <!-- Use WordPress coding standards -->
    <rule ref="WordPress"/>
    
    <!-- PHP Compatibility rules -->
    <rule ref="PHPCompatibility"/>
    
    <!-- Custom rules for theme -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" value="versatile"/>
        </properties>
    </rule>
    
    <!-- Disable short array syntax rule (WordPress allows both) -->
    <rule ref="Generic.Arrays.DisallowShortArraySyntax">
        <severity>0</severity>
    </rule>
</ruleset>
